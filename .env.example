# Copy to .env and fill in your local MySQL / phpMyAdmin values

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Dezyon Store

# MySQL (phpMyAdmin / XAMPP / WAMP)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dezyon_store

# Optional Prisma-style URL (same DB)
DATABASE_URL="mysql://root:@127.0.0.1:3306/dezyon_store"

# Session signing (cookie HMAC) — users/admins login via MySQL `users` table
ADMIN_SESSION_SECRET=change-this-to-a-long-random-string

# Demo accounts after importing database/seed_users.sql (or full schema):
# Admin: admin@dezyon.store / admin123  → /login?panel=admin
# User:  user@dezyon.store  / user123   → /login
